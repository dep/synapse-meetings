      <sparkle:version>5</sparkle:version>
      <sparkle:shortVersionString>0.1.4</sparkle:shortVersionString>
      <sparkle:minimumSystemVersion>14.0</sparkle:minimumSystemVersion>
      <description><![CDATA[<h2>What's new in 0.1.4</h2><ul><li>New native toolbar Record button with proper hover and press states — no more floating pill 💅</li><li>Global hotkey to start/stop recording from anywhere, configurable in Settings → Shortcuts</li></ul>]]></description>
