      <sparkle:version>7</sparkle:version>
      <sparkle:shortVersionString>0.1.6</sparkle:shortVersionString>
      <sparkle:minimumSystemVersion>14.0</sparkle:minimumSystemVersion>
      <description><![CDATA[<h2>What's new in 0.1.6</h2><ul><li>Live transcription appears in real-time as you speak during recording</li><li>Take notes while recording — they're saved automatically and woven into the AI summary</li><li>Commit sidebar now remembers your last repo, branch, and folder</li></ul>]]></description>
