    <item>
      <title>Version 0.3.0</title>
      <pubDate>Tue, 28 Apr 2026 05:58:00 +0000</pubDate>
      <sparkle:version>9</sparkle:version>
      <sparkle:shortVersionString>0.3.0</sparkle:shortVersionString>
      <sparkle:minimumSystemVersion>14.0</sparkle:minimumSystemVersion>
      <description><![CDATA[<h2>What's new in 0.3.0</h2><ul><li>New audio device selection — choose specific input and output devices for recording</li><li>Calendar integration — view today's events and auto-fill meeting titles from your calendar</li><li>Audio device picker in Settings</li><li>Calendar sidebar during recording for quick event selection</li></ul>]]></description>
